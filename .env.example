# ── Asosiy sozlamalar ──────────────────────────
DEBUG=1
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── Ma'lumotlar bazasi ─────────────────────────
DATABASE_URL=postgres://admin:secretpass@db:5432/servicehub_db

# ── Redis / Celery ─────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Telegram Bot (ixtiyoriy) ───────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=chat_id_1,chat_id_2

# ── CORS ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Infobip SMS Sozlamalari ────────────────────
INFOBIP_API_KEY=your_infobip_api_key_here
INFOBIP_BASE_URL=your_infobip_base_url_here
INFOBIP_SENDER=InfoSMS

# ── SMS Provayderi ('none' | 'infobip' | 'eskiz') ─
SMS_PROVIDER=none

# ── Eskiz.uz SMS Sozlamalari (ixtiyoriy) ────────
ESKIZ_EMAIL=your_eskiz_email_here
ESKIZ_PASSWORD=your_eskiz_password_here

